            local Cur=New("Frame",{Parent=SVP,Size=UDim2.new(0,5,0,5),BackgroundColor3=Color3.new(1,1,1),AnchorPoint=Vector2.new(0.5,0.5)},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
            local HBar=New("TextButton",{Parent=PF,Size=UDim2.new(1,-18,0,9),Position=UDim2.new(0,9,0,112),Text="",AutoButtonColor=false},{
                New("UIGradient",{Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromHSV(0,1,1)),ColorSequenceKeypoint.new(0.17,Color3.fromHSV(0.17,1,1)),ColorSequenceKeypoint.new(0.33,Color3.fromHSV(0.33,1,1)),ColorSequenceKeypoint.new(0.5,Color3.fromHSV(0.5,1,1)),ColorSequenceKeypoint.new(0.67,Color3.fromHSV(0.67,1,1)),ColorSequenceKeypoint.new(0.83,Color3.fromHSV(0.83,1,1)),ColorSequenceKeypoint.new(1,Color3.fromHSV(1,1,1))})}),
                New("UICorner",{CornerRadius=UDim.new(0,2)}),
            })
            local H,S,V=0,1,1 local dSV,dH=false,false
            local function UC()
                col=Color3.fromHSV(H,S,V) Prev.BackgroundColor3=col
                SVP.BackgroundColor3=Color3.fromHSV(H,1,1) Cur.Position=UDim2.new(S,0,1-V,0)
                if cfg.Callback then cfg.Callback(col) end
            end
            SVP.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dSV=true end end)
            HBar.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=true end end)
            UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dSV=false dH=false end end)
            UIS.InputChanged:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseMovement then
                    if dSV then
                        local sz=SVP.AbsoluteSize local ps=SVP.AbsolutePosition
                        S=math.clamp((i.Position.X-ps.X)/sz.X,0,1)
                        V=1-math.clamp((i.Position.Y-ps.Y)/sz.Y,0,1) UC()
                    elseif dH then
                        local sz=HBar.AbsoluteSize local ps=HBar.AbsolutePosition
                        H=math.clamp((i.Position.X-ps.X)/sz.X,0,1) UC()
                    end
                end
            end)
            Prev.MouseButton1Click:Connect(function()
                opened=not opened
                Tw(PF,{Size=opened and UDim2.new(0,175,0,165) or UDim2.new(0,175,0,0)},0.2)
            end)
            if cfg.Tooltip then Tip(Wrap,cfg.Tooltip) end
        end

        -- TEXTBOX
        function IF:Textbox(cfg)
            local Wrap=New("Frame",{Parent=Content,Size=UDim2.new(1,0,0,34),BackgroundTransparency=1})
            New("TextLabel",{Parent=Wrap,Text=cfg.Name,TextColor3=CFG.TextDim,TextSize=11,Font=CFG.Font,BackgroundTransparency=1,Size=UDim2.new(1,0,0,14),TextXAlignment=Enum.TextXAlignment.Left})
            local TB=New("TextBox",{Parent=Wrap,Size=UDim2.new(1,0,0,18),Position=UDim2.new(0,0,0,16),BackgroundColor3=CFG.Secondary,TextColor3=CFG.Text,PlaceholderText=cfg.Placeholder or "...",PlaceholderColor3=CFG.TextDim,Text="",Font=CFG.Font,TextSize=11,BorderSizePixel=0},{
                New("UICorner",{CornerRadius=UDim.new(0,4)}),
                New("UIStroke",{Name="TBS",Color=CFG.Stroke}),
                New("UIPadding",{PaddingLeft=UDim.new(0,6)}),
            })
            TB.Focused:Connect(function() Tw(TB:FindFirstChild("TBS"),{Color=CFG.Accent},0.1) end)
            TB.FocusLost:Connect(function()
                Tw(TB:FindFirstChild("TBS"),{Color=CFG.Stroke},0.1)
                if cfg.Callback then cfg.Callback(TB.Text) end
            end)
            if cfg.Tooltip then Tip(Wrap,cfg.Tooltip) end
        end

        -- KEYBIND
        function IF:Keybind(cfg)
            local key=cfg.Default or Enum.KeyCode.Insert
            local waiting=false
            local Wrap=New("Frame",{Parent=Content,Size=UDim2.new(1,0,0,20),BackgroundTransparency=1})
            New("TextLabel",{Parent=Wrap,Text=cfg.Name,TextColor3=CFG.TextDim,TextSize=11,Font=CFG.Font,BackgroundTransparency=1,Size=UDim2.new(0.6,0,1,0),TextXAlignment=Enum.TextXAlignment.Left})
            local KB=New("TextButton",{Parent=Wrap,Size=UDim2.new(0,60,1,0),AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,0,0,0),BackgroundColor3=CFG.Secondary,Text=key.Name,TextColor3=CFG.TextDim,TextSize=10,Font=CFG.Font,AutoButtonColor=false},{
                New("UICorner",{CornerRadius=UDim.new(0,4)}),
                New("UIStroke",{Name="KBS",Color=CFG.Stroke}),
            })
            KB.MouseButton1Click:Connect(function()
                waiting=true KB.Text="..."
                Tw(KB:FindFirstChild("KBS"),{Color=CFG.Accent},0.1)
                Tw(KB,{TextColor3=CFG.Accent},0.1)
            end)
            UIS.InputBegan:Connect(function(i)
                if waiting and i.UserInputType==Enum.UserInputType.Keyboard then
                    waiting=false key=i.KeyCode KB.Text=key.Name
                    Tw(KB:FindFirstChild("KBS"),{Color=CFG.Stroke},0.1)
                    Tw(KB,{TextColor3=CFG.TextDim},0.1)
                    if cfg.Callback then cfg.Callback(key) end
                end
            end)
            if cfg.Tooltip then Tip(Wrap,cfg.Tooltip) end
        end

        -- BUTTON
        function IF:Button(cfg)
            local bc = cfg.Variant=="Primary" and CFG.Accent
                    or cfg.Variant=="Danger"  and Color3.fromRGB(210,50,50)
                    or CFG.Secondary
            local tc = (cfg.Variant=="Primary" or cfg.Variant=="Danger")
                    and Color3.new(0,0,0) or CFG.TextDim
            local Btn=New("TextButton",{
                Parent=Content, Size=UDim2.new(1,0,0,24),
                BackgroundColor3=bc, Text=cfg.Name, TextColor3=tc,
                Font=Enum.Font.GothamBold, TextSize=10, AutoButtonColor=false,
            },{
                New("UICorner",{CornerRadius=UDim.new(0,5)}),
                New("UIStroke",{Color=CFG.Stroke,Thickness=1}),
            })
            Btn.MouseEnter:Connect(function()
                Tw(Btn,{BackgroundColor3=Color3.new(
                    math.clamp(bc.R+0.09,0,1),
                    math.clamp(bc.G+0.09,0,1),
                    math.clamp(bc.B+0.09,0,1))},0.1)
            end)
            Btn.MouseLeave:Connect(function() Tw(Btn,{BackgroundColor3=bc},0.1) end)
            Btn.MouseButton1Down:Connect(function() Tw(Btn,{Size=UDim2.new(0.95,0,0,20)},0.07) end)
            Btn.MouseButton1Up:Connect(function()
                Tw(Btn,{Size=UDim2.new(1,0,0,24)},0.14,Enum.EasingStyle.Back)
                if cfg.Callback then cfg.Callback() end
            end)
            if cfg.Tooltip then Tip(Btn,cfg.Tooltip) end
        end

        return IF
    end -- Group
    return GF
end -- Tab

-- ============================================================
--  BALL — drag vs click detection
-- ============================================================
local BSIZ = 66
local _ballDragging = false
local _ballDown     = false
local _ballDownPos  = nil
local _ballStartPos = nil
local DRAG_THRESH   = 9

local BallHolder = New("Frame",{
    Parent=SG,
    Size=UDim2.fromOffset(BSIZ,BSIZ),
    Position=UDim2.new(0.5,-BSIZ/2,0,10),
    BackgroundTransparency=1, ZIndex=200,
})

local _glowRings={}
for i,d in ipairs({{8,0.3},{17,0.58},{26,0.8}}) do
    local pad,tr=d[1],d[2]
    local ring=New("Frame",{
        Parent=BallHolder,
        Size=UDim2.fromOffset(BSIZ+pad*2,BSIZ+pad*2),
        Position=UDim2.fromOffset(-pad,-pad),
        BackgroundTransparency=1, ZIndex=197,
    },{
        New("UICorner",{CornerRadius=UDim.new(1,0)}),
        New("UIStroke",{Color=CFG.Accent,Thickness=2,Transparency=tr}),
    })
    table.insert(_glowRings, ring:FindFirstChildOfClass("UIStroke"))
end

local Ball = New("Frame",{
    Parent=BallHolder,
    Size=UDim2.fromOffset(BSIZ,BSIZ),
    BackgroundColor3=Color3.fromRGB(14,9,26),
    BorderSizePixel=0,
    ZIndex=200,
    ClipsDescendants=true,
},{
    New("UICorner",{CornerRadius=UDim.new(1,0)}),
    New("UIStroke",{Name="BS",Color=CFG.Accent,Thickness=2}),
    New("UIGradient",{
        Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,Color3.fromRGB(32,18,58)),
            ColorSequenceKeypoint.new(1,Color3.fromRGB(10,7,20)),
        }),Rotation=135,
    }),
})

-- Ícone circular: o próprio Ball tem ClipsDescendants=true e UICorner(1,0)
-- então o ImageLabel fica recortado em círculo automaticamente
local BallIcon = New("ImageLabel",{
    Parent=Ball,
    Size=UDim2.new(0.72,0,0.72,0),
    Position=UDim2.new(0.14,0,0.14,0),
    BackgroundTransparency=1,
    Image="rbxassetid://70948224300476",
    ImageColor3=CFG.Accent,
    ScaleType=Enum.ScaleType.Fit,
    ZIndex=201,
})

local BallBtn = New("TextButton",{
    Parent=BallHolder,
    Size=UDim2.fromOffset(BSIZ,BSIZ),
    BackgroundTransparency=1,
    Text="", ZIndex=202,
})

task.spawn(function()
    local BS=Ball:FindFirstChild("BS")
    while not Library._dead do
        local t=tick()
        for i,r in ipairs(_glowRings) do
            local p=(t*1.3+(i-1)*0.55)%(math.pi*2)
            local v=0.5+0.5*math.sin(p)
            r.Transparency=0.12+v*0.78
            r.Color=Color3.fromHSV(0.73+math.sin(t*0.25+i)*0.04,0.55,0.92)
        end
        if BS then
            local v=0.5+0.5*math.sin(t*1.7)
            BS.Color=Color3.fromHSV(0.73,0.35+v*0.35,1)
            BallIcon.ImageColor3=Color3.fromHSV(0.73,0.25+v*0.35,1)
        end
        task.wait(0.04)
    end
end)

task.spawn(function()
    local t=0
    while not Library._dead do
        t=t+0.04
        if not _ballDragging then
            local cur=BallHolder.Position
            BallHolder.Position=UDim2.new(cur.X.Scale,cur.X.Offset,cur.Y.Scale,cur.Y.Offset+math.sin(t)*0.4)
        end
        task.wait(0.04)
    end
end)

BallBtn.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        _ballDown=true
        _ballDragging=false
        _ballDownPos=Vector2.new(i.Position.X,i.Position.Y)
        _ballStartPos=Vector2.new(BallHolder.Position.X.Offset,BallHolder.Position.Y.Offset)
    end
end)

UIS.InputChanged:Connect(function(i)
    if not _ballDown then return end
    if i.UserInputType~=Enum.UserInputType.MouseMovement and i.UserInputType~=Enum.UserInputType.Touch then return end
    local cur=Vector2.new(i.Position.X,i.Position.Y)
    local delta=cur-_ballDownPos
    if not _ballDragging and delta.Magnitude>DRAG_THRESH then
        _ballDragging=true
    end
    if _ballDragging then
        local vp=workspace.CurrentCamera.ViewportSize
        local sc=UIScale.Scale
        local nx=math.clamp(_ballStartPos.X+delta.X/sc, 0, vp.X/sc-BSIZ)
        local ny=math.clamp(_ballStartPos.Y+delta.Y/sc, 0, vp.Y/sc-BSIZ)
        BallHolder.Position=UDim2.new(0,nx,0,ny)
    end
end)

local _winVisible=true

UIS.InputEnded:Connect(function(i)
    if not _ballDown then return end
    if i.UserInputType~=Enum.UserInputType.MouseButton1 and i.UserInputType~=Enum.UserInputType.Touch then return end
    local wasDrag=_ballDragging
    _ballDown=false
    _ballDragging=false

    if not wasDrag then
        _winVisible=not _winVisible
        Tw(Ball,{Size=UDim2.fromOffset(BSIZ-8,BSIZ-8)},0.07)
        task.spawn(function()
            task.wait(0.08)
            Tw(Ball,{Size=UDim2.fromOffset(BSIZ,BSIZ)},0.16,Enum.EasingStyle.Back)
        end)
        if _winVisible then
            Win.Visible=true
            Win.Size=UDim2.fromOffset(0,0)
            Tw(Win,{Size=UDim2.fromOffset(CFG.W,CFG.H)},0.36,Enum.EasingStyle.Back)
        else
            Tw(Win,{Size=UDim2.fromOffset(0,0)},0.26,Enum.EasingStyle.Quad)
            task.wait(0.28)
            Win.Visible=false
            Win.Size=UDim2.fromOffset(CFG.W,CFG.H)
        end
    end
end)

UIS.InputBegan:Connect(function(i,gpe)
    if not gpe and i.KeyCode==Library.MenuKey then
        _winVisible=not _winVisible
        if _winVisible then
            Win.Visible=true Win.Size=UDim2.fromOffset(0,0)
            Tw(Win,{Size=UDim2.fromOffset(CFG.W,CFG.H)},0.36,Enum.EasingStyle.Back)
        else
            Tw(Win,{Size=UDim2.fromOffset(0,0)},0.26,Enum.EasingStyle.Quad)
            task.wait(0.28) Win.Visible=false
            Win.Size=UDim2.fromOffset(CFG.W,CFG.H)
        end
    end
end)

Library:Notify("Vortex Union carregado!", "success")
Library:Notify("Bem-vindo · v3.0")

return Library
