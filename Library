-- ── helpers ──────────────────────────────────────────────
local function New(cls, props, kids)
    local o = Instance.new(cls)
    for k,v in pairs(props or {}) do o[k]=v end
    for _,c in pairs(kids  or {}) do c.Parent=o end
    return o
end
local function Tw(obj, goal, t, sty, dir)
    TweenService:Create(obj, TweenInfo.new(t or .18,
        sty or Enum.EasingStyle.Quad,
        dir or Enum.EasingDirection.Out), goal):Play()
end
local function GTS(t,s,f)
    return TextService:GetTextSize(t,s,f,Vector2.new(9999,9999))
end

