            local Wrap=New("Frame",{Parent=Content,Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,ZIndex=15})
            New("TextLabel",{Parent=Wrap,Text=cfg.Name,TextColor3=CFG.TextDim,TextSize=11,Font=CFG.Font,BackgroundTransparency=1,Size=UDim2.new(0.65,0,1,0),TextXAlignment=Enum.TextXAlignment.Left})
            local Prev=New("TextButton",{Parent=Wrap,Size=UDim2.new(0,28,0,13),AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,0,0.5,0),BackgroundColor3=col,Text="",AutoButtonColor=false},{New("UIStroke",{Color=CFG.Stroke}),New("UICorner",{CornerRadius=UDim.new(0,3)})})
            local PF=New("Frame",{Parent=Prev,Size=UDim2.new(0,175,0,0),Position=UDim2.new(1,0,1,4),AnchorPoint=Vector2.new(1,0),BackgroundColor3=CFG.Main,BorderSizePixel=0,ClipsDescendants=true,ZIndex=65},{New("UIStroke",{Color=CFG.Stroke}),New("UICorner",{CornerRadius=UDim.new(0,4)})})
            local SVP=New("TextButton",{Parent=PF,Size=UDim2.new(1,-18,0,95),Position=UDim2.new(0,9,0,9),BackgroundColor3=Color3.fromHSV(0,1,1),Text="",AutoButtonColor=false},{
                New("ImageLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Image="rbxassetid://4801885019"}),
                New("ImageLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Image="rbxassetid://4801885019",ImageColor3=Color3.new(0,0,0),Rotation=90}),
