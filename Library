function Library:Tab(name, iconId)
    local TabBtn = New("TextButton",{
        Parent=Sidebar,
        Size=UDim2.new(0,36,0,36),
        BackgroundColor3=CFG.Main,
        Text="", AutoButtonColor=false,
        LayoutOrder=#self._tabs+1,
    },{
        New("UICorner",{CornerRadius=UDim.new(0,8)}),
        New("UIStroke",{Name="TStr",Color=CFG.Stroke,Thickness=1}),
    })

    local Ico = New("ImageLabel",{
        Name="Ico",
        Parent=TabBtn,
        Size=UDim2.new(0.62,0,0.62,0),
        Position=UDim2.new(0.19,0,0.19,0),
        BackgroundTransparency=1,
        Image="rbxassetid://"..tostring(iconId),
        ImageColor3=CFG.TextDim,
        ScaleType=Enum.ScaleType.Fit,
    })

    local Page = New("ScrollingFrame",{
        Parent=PagesFrame,
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1, Visible=false,
        ScrollBarThickness=2,
        ScrollBarImageColor3=CFG.Accent,
        CanvasSize=UDim2.new(0,0,0,0),
        AutomaticCanvasSize=Enum.AutomaticSize.Y,
        BorderSizePixel=0,
    })
    New("UIPadding",{Parent=Page,
        PaddingTop=UDim.new(0,10),PaddingLeft=UDim.new(0,10),
        PaddingRight=UDim.new(0,10),PaddingBottom=UDim.new(0,10),
    })
    local LeftCol = New("Frame",{
        Parent=Page, Size=UDim2.new(0.495,0,0,0),
        AutomaticSize=Enum.AutomaticSize.Y, BackgroundTransparency=1,
    },{New("UIListLayout",{Padding=UDim.new(0,8),SortOrder=Enum.SortOrder.LayoutOrder})})
    local RightCol = New("Frame",{
        Parent=Page, Size=UDim2.new(0.495,0,0,0),
        Position=UDim2.new(0.505,0,0,0),
        AutomaticSize=Enum.AutomaticSize.Y, BackgroundTransparency=1,
    },{New("UIListLayout",{Padding=UDim.new(0,8),SortOrder=Enum.SortOrder.LayoutOrder})})

    local TStr = TabBtn:FindFirstChild("TStr")
    local tabData = {Btn=TabBtn, Page=Page, Ico=Ico, Str=TStr}
    table.insert(self._tabs, tabData)

    local function Activate()
        for _,t in ipairs(Library._tabs) do
            Tw(t.Btn,{BackgroundColor3=CFG.Main},0.15)
            Tw(t.Ico,{ImageColor3=CFG.TextDim},0.15)
            Tw(t.Str,{Color=CFG.Stroke,Transparency=0},0.15)
            t.Page.Visible=false
        end
        Tw(TabBtn,{BackgroundColor3=CFG.Secondary},0.15)
        Tw(Ico,{ImageColor3=CFG.Accent},0.15)
        Tw(TStr,{Color=CFG.Accent,Transparency=0.25},0.15)
        Page.Visible=true
    end

    TabBtn.MouseButton1Click:Connect(Activate)
    TabBtn.MouseEnter:Connect(function()
        if not Page.Visible then Tw(TabBtn,{BackgroundColor3=Color3.fromRGB(22,17,36)},0.1) end
    end)
    TabBtn.MouseLeave:Connect(function()
        if not Page.Visible then Tw(TabBtn,{BackgroundColor3=CFG.Main},0.1) end
    end)
    if #self._tabs==1 then Activate() end

    local GF={}
    local _leftNext=true

    -- ── GROUP ─────────────────────────────────────────────
    function GF:Group(title)
        local col = _leftNext and LeftCol or RightCol
        _leftNext  = not _leftNext

        local GFrame = New("Frame",{
            Parent=col, Size=UDim2.new(1,0,0,0),
            AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundColor3=CFG.Panel, BorderSizePixel=0,
        },{
            New("UICorner",{CornerRadius=UDim.new(0,5)}),
            New("UIStroke",{Name="GStr",Color=CFG.Stroke,Thickness=1}),
        })

        local gs = GFrame:FindFirstChild("GStr")
        task.spawn(function()
            local h=0
            while not Library._dead and gs and gs.Parent do
                h=(h+0.004)%1
                gs.Color=Color3.fromHSV(h,0.5,0.6)
                task.wait(0.05)
            end
        end)

        New("Frame",{
            Parent=GFrame, Size=UDim2.new(1,0,0,24),
            BackgroundColor3=CFG.Secondary, BorderSizePixel=0,
        },{
            New("UICorner",{CornerRadius=UDim.new(0,5)}),
            New("Frame",{Size=UDim2.new(1,0,0,8),Position=UDim2.new(0,0,1,-7),BackgroundColor3=CFG.Secondary}),
            New("Frame",{
                Size=UDim2.new(0,3,0,13),Position=UDim2.new(0,7,0.5,-6),
                BackgroundColor3=CFG.Accent,
            },{New("UICorner",{CornerRadius=UDim.new(1,0)})}),
            New("TextLabel",{
                Text=title, Font=Enum.Font.GothamBold, TextSize=11,
                TextColor3=CFG.Text, BackgroundTransparency=1,
                Size=UDim2.new(1,-18,1,0), Position=UDim2.new(0,16,0,0),
                TextXAlignment=Enum.TextXAlignment.Left,
            }),
        })

        local Content = New("Frame",{
            Parent=GFrame, Size=UDim2.new(1,0,0,0),
            Position=UDim2.new(0,0,0,24),
            AutomaticSize=Enum.AutomaticSize.Y, BackgroundTransparency=1,
        },{
            New("UIListLayout",{Padding=UDim.new(0,4),SortOrder=Enum.SortOrder.LayoutOrder}),
            New("UIPadding",{
                PaddingTop=UDim.new(0,7),PaddingBottom=UDim.new(0,7),
                PaddingLeft=UDim.new(0,8),PaddingRight=UDim.new(0,8),
            }),
        })

        local IF={}

        -- TOGGLE
        function IF:Toggle(cfg)
            local on = cfg.Default or false
            local Row = New("TextButton",{
                Parent=Content, Size=UDim2.new(1,0,0,24),
                BackgroundColor3=CFG.Secondary, Text="", AutoButtonColor=false,
            },{
                New("UICorner",{CornerRadius=UDim.new(0,5)}),
                New("UIStroke",{Name="RS",Color=CFG.Stroke,Thickness=1}),
            })
            local Lbl = New("TextLabel",{
                Parent=Row, Text=cfg.Name,
                TextColor3=on and CFG.Text or (cfg.Risky and Color3.fromRGB(220,65,65) or CFG.TextDim),
                TextSize=11, Font=CFG.Font, BackgroundTransparency=1,
                Position=UDim2.new(0,9,0,0),
                Size=UDim2.new(1,-48,1,0),
                TextXAlignment=Enum.TextXAlignment.Left,
            })
            local Track = New("Frame",{
                Parent=Row, Size=UDim2.new(0,30,0,14),
                Position=UDim2.new(1,-36,0.5,-7),
                BackgroundColor3=on and CFG.Accent or Color3.fromRGB(30,25,48),
                BorderSizePixel=0,
            },{
                New("UICorner",{CornerRadius=UDim.new(1,0)}),
                New("UIStroke",{Color=CFG.Stroke,Thickness=1}),
            })
            local Thumb = New("Frame",{
                Parent=Track,
                Size=UDim2.new(0,10,0,10),
                Position=on and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5),
                BackgroundColor3=Color3.new(1,1,1),
            },{New("UICorner",{CornerRadius=UDim.new(1,0)})})
            local RS = Row:FindFirstChild("RS")

            local function Set(v, fire)
                on=v
                Tw(Track,{BackgroundColor3=on and CFG.Accent or Color3.fromRGB(30,25,48)},0.18)
                Tw(Thumb,{Position=on and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5)},0.18)
                Tw(Lbl,{TextColor3=on and CFG.Text or (cfg.Risky and Color3.fromRGB(220,65,65) or CFG.TextDim)},0.15)
                Tw(RS,{Color=on and CFG.Accent or CFG.Stroke},0.18)
                if fire and cfg.Callback then cfg.Callback(on) end
            end
            Set(on, false)

            Row.MouseButton1Click:Connect(function() Set(not on, true) end)
            Row.MouseEnter:Connect(function() Tw(Row,{BackgroundColor3=Color3.fromRGB(25,20,40)},0.1) end)
            Row.MouseLeave:Connect(function() Tw(Row,{BackgroundColor3=CFG.Secondary},0.1) end)
            if cfg.Tooltip then Tip(Row,cfg.Tooltip) end
            return {Set=function(v) Set(v,true) end, Get=function() return on end}
        end

        -- SLIDER
        function IF:Slider(cfg)
            local val=cfg.Default or cfg.Min
            local drag=false
            local Wrap=New("Frame",{Parent=Content,Size=UDim2.new(1,0,0,36),BackgroundTransparency=1})
            New("TextLabel",{Parent=Wrap,Text=cfg.Name,TextColor3=CFG.TextDim,TextSize=11,Font=CFG.Font,BackgroundTransparency=1,Size=UDim2.new(0.7,0,0,15),TextXAlignment=Enum.TextXAlignment.Left})
            local VLbl=New("TextLabel",{Parent=Wrap,Text=val..(cfg.Unit or ""),TextColor3=CFG.Accent,TextSize=11,Font=CFG.Font,BackgroundTransparency=1,Size=UDim2.new(1,0,0,15),TextXAlignment=Enum.TextXAlignment.Right})
            local Track=New("Frame",{Parent=Wrap,Size=UDim2.new(1,0,0,6),Position=UDim2.new(0,0,0,22),BackgroundColor3=CFG.Secondary,BorderSizePixel=0},{
                New("UICorner",{CornerRadius=UDim.new(1,0)}),
                New("UIStroke",{Color=CFG.Stroke}),
            })
            local Fill=New("Frame",{Parent=Track,Size=UDim2.new(0,0,1,0),BackgroundColor3=CFG.Accent},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
            local function Apply(inp)
                local p=math.clamp((inp.Position.X-Track.AbsolutePosition.X)/Track.AbsoluteSize.X,0,1)
                val=math.floor(cfg.Min+(cfg.Max-cfg.Min)*p)
                Tw(Fill,{Size=UDim2.new(p,0,1,0)},0.04)
                VLbl.Text=val..(cfg.Unit or "")
                if cfg.Callback then cfg.Callback(val) end
            end
            Wrap.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true Apply(i) end end)
            UIS.InputChanged:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseMovement then Apply(i) end end)
            UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
            Fill.Size=UDim2.new((val-cfg.Min)/(cfg.Max-cfg.Min),0,1,0)
            if cfg.Tooltip then Tip(Wrap,cfg.Tooltip) end
        end

        -- DROPDOWN
        function IF:Dropdown(cfg)
            local cur=cfg.Default or cfg.Options[1]
            local open=false
            local Wrap=New("Frame",{Parent=Content,Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,ZIndex=20})
            New("TextLabel",{Parent=Wrap,Text=cfg.Name,TextColor3=CFG.TextDim,TextSize=11,Font=CFG.Font,BackgroundTransparency=1,Size=UDim2.new(1,0,0,15),TextXAlignment=Enum.TextXAlignment.Left})
            local Box=New("TextButton",{Parent=Wrap,Size=UDim2.new(1,0,0,20),Position=UDim2.new(0,0,0,16),BackgroundColor3=CFG.Secondary,Text="",AutoButtonColor=false},{
                New("UICorner",{CornerRadius=UDim.new(0,4)}),
                New("UIStroke",{Color=CFG.Stroke}),
                New("TextLabel",{Name="Val",Text=cur,Size=UDim2.new(1,-20,1,0),Position=UDim2.new(0,6,0,0),BackgroundTransparency=1,TextColor3=CFG.Text,TextSize=11,Font=CFG.Font,TextXAlignment=Enum.TextXAlignment.Left}),
                New("TextLabel",{Text="▾",Size=UDim2.new(0,18,1,0),Position=UDim2.new(1,-18,0,0),BackgroundTransparency=1,TextColor3=CFG.Accent,TextSize=13}),
            })
            local List=New("ScrollingFrame",{Parent=Box,Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,2),BackgroundColor3=CFG.Panel,BorderSizePixel=0,Visible=false,ZIndex=60,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,ScrollBarThickness=2},{
                New("UICorner",{CornerRadius=UDim.new(0,4)}),
                New("UIStroke",{Color=CFG.Stroke}),
                New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder}),
            })
            for _,opt in ipairs(cfg.Options) do
