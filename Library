function Library:Notify(msg, kind)
    local col = kind=="success" and Color3.fromRGB(90,255,130)
             or kind=="error"   and Color3.fromRGB(255,75,75)
             or CFG.Accent
    local f = New("Frame",{
        Parent=NotifHolder,
        Size=UDim2.new(0,0,0,48),
        BackgroundColor3=CFG.Panel, BorderSizePixel=0,
        ClipsDescendants=true,
    },{
        New("UICorner",{CornerRadius=UDim.new(0,6)}),
        New("UIStroke",{Color=col,Thickness=1,Transparency=0.35}),
        New("Frame",{
            Size=UDim2.new(0,3,1,0),
            BackgroundColor3=col,
        },{New("UICorner",{CornerRadius=UDim.new(0,3)})}),
        New("TextLabel",{
            Text=msg, TextColor3=CFG.Text,
            Font=CFG.Font, TextSize=14,
            Size=UDim2.new(1,-16,1,0),
            Position=UDim2.new(0,13,0,0),
            BackgroundTransparency=1,
            TextXAlignment=Enum.TextXAlignment.Left,
            TextWrapped=true,
        }),
    })
    Tw(f,{Size=UDim2.new(0,305,0,52)},0.42,Enum.EasingStyle.Back)
    task.delay(4,function()
        Tw(f,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},0.3)
        task.wait(0.35) f:Destroy()
    end)
end

